# =============================================
# OfferPilot - CareerPilot 环境变量配置
# =============================================
#
# 使用方式：
#   1. 复制此文件为 .env
#   2. 按自己的模型供应商填写对应 Key
#   3. 所有后端模块都从项目根目录 .env 读取配置
#   4. LLM_API_URL / LLM_MODEL 要和 Key 对应的供应商保持一致
# =============================================

# ===== LLM / 模型配置 =====
LLM_API_KEY=YOUR_API_KEY_HERE
LLM_API_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 兼容旧模块的供应商 Key（按实际使用情况填写）
DASHSCOPE_API_KEY=your_qwen_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000
RESUME_SERVICE_URL=http://localhost:8001/api/resume/upload

# ===== 文件存储 =====
UPLOAD_DIR=uploads
RESUME_STORAGE_DIR=dataset/resumes
JD_STORAGE_DIR=dataset/jd

