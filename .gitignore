# =============================================
# OfferPilot .gitignore
# =============================================

# dependencies
node_modules/
frontend/node_modules/

# build output
dist/
frontend/dist/
coverage/
build/
htmlcov/

# vite cache
.vite/
frontend/.vite/

# local caches
.cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# 环境变量（含 API Key）
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/
*.egg
.Python
.pytest_cache/
.coverage
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sw?
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# OS
.DS_Store
Thumbs.db
Desktop.ini

# 项目运行时
*.log
logs/
uploads/
test_output/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 数据文件（根据情况决定是否提交）
dataset/parsed_resume/
dataset/resumes/
dataset/interview/
dataset/jobs/
dataset/knowledge/

# 临时文件
*.tmp
*.temp
*.pdf
*.docx
!test_resume.pdf
*.zip
*.tar.gz
